{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure (win-debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "win-debug"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Configure (win-release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "win-release"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Configure (wsl-debug)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "wsl-debug"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Configure (wsl-release)",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "wsl-release"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Delta++UI (win-debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "win-debug-build",
                "--target",
                "Delta++UI"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (win-debug)"],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Build Delta++UI (win-release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "win-release-build",
                "--target",
                "Delta++UI"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (win-release)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Build Delta++_Test (wsl-debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "wsl-debug-build",
                "--target",
                "Delta++_Test"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (wsl-debug)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build Delta++_Test (wsl-release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "wsl-release-build",
                "--target",
                "Delta++_Test"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (wsl-release)"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Delta Tests (win-debug)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build/win/vs2022-debug",
                "-C",
                "Debug",
                "-R",
                "^DeltaPP\\.",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (win-debug)"],
            "dependsOrder": "sequence",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Delta Tests (win-release)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build/win/vs2022-release",
                "-C",
                "Release",
                "-R",
                "^DeltaPP\\.",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (win-release)"],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run Delta Tests (wsl-debug)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build/wsl/make-debug",
                "-R",
                "^DeltaPP\\.",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (wsl-debug)"],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "Run Delta Tests (wsl-release)",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir",
                "${workspaceFolder}/build/wsl/make-release",
                "-R",
                "^DeltaPP\\.",
                "--output-on-failure"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["Configure (wsl-release)"],
            "dependsOrder": "sequence",
            "group": "test",
            "problemMatcher": []
        }
    ]
}
